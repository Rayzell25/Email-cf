# ============================================================================
#  CLOUDFLARE EMAIL MANAGER BOT - Contoh konfigurasi environment
#  Salin file ini menjadi .env lalu isi nilainya. JANGAN commit .env ke git.
# ============================================================================

# --- Telegram Bot ---------------------------------------------------------
# Token bot dari @BotFather
TELEGRAM_BOT_TOKEN=
# Telegram user ID pemilik (hanya ID ini yang boleh memakai bot). Wajib.
TELEGRAM_OWNER_ID=

# --- Cloudflare -----------------------------------------------------------
# API Token dengan permission minimum:
#   Zone > Email Routing Rules > Edit
#   Zone > Zone > Read
#   Account > Email Routing Addresses > Read
CLOUDFLARE_API_TOKEN=
# Account ID Cloudflare (untuk membaca destination addresses)
CLOUDFLARE_ACCOUNT_ID=

# Alamat tujuan default untuk forwarding email (harus sudah diverifikasi di Cloudflare)
DEFAULT_DESTINATION_EMAIL=

# --- Database -------------------------------------------------------------
DATABASE_URL=sqlite+aiosqlite:///data/bot.db

# --- Local Bot API (respon cepat) -----------------------------------------
# Kosongkan untuk memakai server resmi https://api.telegram.org
# Untuk respon cepat + premium emoji di tombol, jalankan telegram-bot-api lokal
# (lihat docker-compose.yml) lalu isi: http://telegram-bot-api:8081
BOT_API_ROOT=

# Kredensial aplikasi Telegram dari https://my.telegram.org (untuk Local Bot API server).
# Sudah diisi default (akun yang kamu siapkan khusus untuk bot). Ganti bila perlu.
TELEGRAM_API_ID=32773999
TELEGRAM_API_HASH=d2eb7260911dbce615a1fb27f36d4b12

# --- Redis (cache session FSM, opsional) ----------------------------------
# Kosongkan untuk memakai penyimpanan in-memory.
REDIS_URL=

# --- Premium / Custom Emoji (opsional) ------------------------------------
# 1 = aktifkan premium emoji (butuh owner Telegram Premium + Local Bot API 9.4+)
# 0 = pakai unicode emoji biasa
USE_PREMIUM_EMOJI=0

# --- Perilaku / limit -----------------------------------------------------
NAME_RESERVATION_MINUTES=10
MAX_GENERATION_ATTEMPTS=100
DOMAIN_PAGE_SIZE=20
EMAIL_PAGE_SIZE=20
